<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="MyFirstApp.MainWindow"
        Width="1280"
        Height="720"
        Title="Simple Clicker"
        Background="#181818">

    <Grid RowDefinitions="Auto,*,Auto"
          Margin="25">

        <!-- HEADER -->
        <Border Grid.Row="0"
                Background="#242424"
                CornerRadius="15"
                Padding="18"
                Margin="0,0,0,20">

            <TextBlock Text="SIMPLE CLICKER"
                       FontSize="42"
                       FontWeight="ExtraBold"
                       Foreground="White"
                       HorizontalAlignment="Center"/>
        </Border>

        <!-- MAIN -->
        <Grid Grid.Row="1"
              ColumnDefinitions="300,*,300"
              RowDefinitions="*,*"
              ColumnSpacing="25"
              RowSpacing="25">

            <!-- UPGRADES -->
            <Border Grid.Column="0"
                    Grid.Row="0"
                    Background="#242424"
                    BorderBrush="#3D8BFF"
                    BorderThickness="2"
                    CornerRadius="15"
                    Padding="20">

                <StackPanel Spacing="15">

                    <TextBlock Text="UPGRADES"
                               FontSize="28"
                               FontWeight="Bold"
                               Foreground="#3D8BFF"/>

                    <Separator/>

                    <TextBlock x:Name="InfoText"
                               Text="Clicks per click: 1"
                               FontSize="18"
                               Foreground="White"/>

                    <TextBlock x:Name="UpgradeText"
                               Text="Upgrade Cost: 20"
                               FontSize="18"
                               Foreground="White"/>

                    <Button Content="BUY UPGRADE"
                            Height="30"
                            FontSize="15"
                            Click="Upgrade_Button"/>
                </StackPanel>

            </Border>

            <!-- CENTER -->
            <Grid Grid.Column="1"
                  Grid.RowSpan="2"
                  RowDefinitions="Auto,Auto,Auto,*"
                  HorizontalAlignment="Center"
                  VerticalAlignment="Center">

                <TextBlock Text="CURRENT SCORE"
                           FontSize="18"
                           Foreground="#888888"
                           HorizontalAlignment="Center"/>

                <Border Grid.Row="1"
                        Background="#242424"
                        BorderBrush="#3A3A3A"
                        BorderThickness="1"
                        CornerRadius="15"
                        Padding="25"
                        Margin="0,10">

                    <TextBlock x:Name="ScoreText"
                               Text="0"
                               FontSize="72"
                               FontWeight="ExtraBold"
                               Foreground="White"
                               HorizontalAlignment="Center"/>
                </Border>

                <Button Grid.Row="2"
                        x:Name="ClickButton"
                        Content="CLICK"
                        Width="450"
                        Height="160"
                        FontSize="42"
                        FontWeight="Bold"
                        HorizontalAlignment="Center"
                        HorizontalContentAlignment="Center"
                        VerticalContentAlignment="Center"
                        Margin="0,15"
                        Click="Click_Button"/>

                <TextBlock Grid.Row="3"
                           Text="Earn points and become stronger."
                           FontSize="14"
                           Foreground="#777777"
                           HorizontalAlignment="Center"
                           Margin="0,10"/>
            </Grid>

            <!-- AUTO CLICKERS -->
            <Border Grid.Column="2"
                    Grid.Row="0"
                    Background="#242424"
                    BorderBrush="#4CAF50"
                    BorderThickness="2"
                    CornerRadius="15"
                    Padding="20">

                <StackPanel Spacing="15">

                    <TextBlock Text="AUTO CLICKERS"
                               FontSize="28"
                               FontWeight="Bold"
                               Foreground="#4CAF50"/>

                    <Separator/>

                    <TextBlock x:Name="AutoClickerCountText"
                               Text="Owned: 0"
                               FontSize="18"
                               Foreground="White"/>

                    <TextBlock x:Name="AutoClickerCostText"
                               Text="Cost: 100"
                               FontSize="18"
                               Foreground="White"/>

                    <Button Content="BUY AUTO CLICKER"
                            Height="30"
                            FontSize="15"
                            Click="AutoClicker_Button"/>
                </StackPanel>

            </Border>

            <!-- PRESTIGE -->
            <Border Grid.Column="0"
                    Grid.Row="1"
                    Background="#242424"
                    BorderBrush="#FFD54A"
                    BorderThickness="2"
                    CornerRadius="15"
                    Padding="20">

                <StackPanel Spacing="15">

                    <TextBlock Text="PRESTIGE"
                               FontSize="28"
                               FontWeight="Bold"
                               Foreground="#FFD54A"/>

                    <Separator/>

                    <TextBlock x:Name="PrestigeText"
                               Text="Multiplier: x1"
                               FontSize="18"
                               Foreground="White"/>

                    <ProgressBar x:Name="PrestigeProgress"
                                 Height="28"
                                 Minimum="0"
                                 Maximum="1000"
                                 Value="0"/>

                    <Button Content="ASCEND"
                            Height="30"
                            FontSize="15"
                            Click="Prestige_Button"/>
                </StackPanel>

            </Border>

            <!-- STATISTICS -->
            <Border Grid.Column="2"
                    Grid.Row="1"
                    Background="#242424"
                    BorderBrush="#666666"
                    BorderThickness="1"
                    CornerRadius="15"
                    Padding="20">

                <StackPanel Spacing="12">

                    <TextBlock Text="STATISTICS"
                               FontSize="28"
                               FontWeight="Bold"
                               Foreground="White"/>

                    <Separator/>

                    <TextBlock x:Name="PlayTime"
						       Text="Play Time: 00:00:00"
                               FontSize="18"
                               Foreground="White"/>

                    <TextBlock x:Name="Prestiges"
						       Text="Prestiges: 1"
                               FontSize="18"
                               Foreground="White"/>

                    <TextBlock x:Name="TotalClicks"
						       Text="Total Clicks: 0"
                               FontSize="18"
                               Foreground="White"/>

                </StackPanel>

            </Border>

        </Grid>

        <!-- FOOTER -->
        <Border Grid.Row="2"
                Background="#242424"
                CornerRadius="15"
                Padding="15"
                Margin="0,20,0,0">

            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Center"
                        Spacing="20">

                <Button Content="SAVE"
                        Width="150"
                        Height="50"
                        FontSize="16"
                        Click="Save_Button"/>

                <Button Content="LOAD"
                        Width="150"
                        Height="50"
                        FontSize="16"
                        Click="Load_Button"/>

                <Button Content="RESET"
                        Width="150"
                        Height="50"
                        FontSize="16"
                        Click="Reset_Button"/>
            </StackPanel>

        </Border>

    </Grid>

</Window>